generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Project {
  id         Int      @id @default(autoincrement())
  slug       String   @unique
  name       String
  desc       String
  longDesc   String
  tech       String[]
  githubUrl  String
  liveUrl    String?
  gradient   String
  features   String[]
  challenges String
  viewCount  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
